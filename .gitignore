# Unity project .gitignore
# Place this file in the root directory next to Assets, Packages and ProjectSettings.

# Unity generated folders
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

*.log
*.blend1
*.blend1.meta

# Captures and recordings
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset Store Tools
# Odkomentuj tylko jeśli zainstalujesz stare Asset Store Tools:
# /[Aa]ssets/AssetStoreTools*

# Rider / JetBrains
/[Aa]ssets/Plugins/Editor/JetBrains*
.idea/
*.DotSettings.user

# Visual Studio / VS Code
.vs/
.vscode/

# Gradle
.gradle/

# Generated IDE project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Generated Unity meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
mono_crash.*
*.stackdump

# Builds and exported packages
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# Unity Test Runner
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables generated content
/ServerData
/[Aa]ssets/[Ss]treamingAssets/aa*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml*
/[Aa]ssets/[Aa]ddressables_[Tt]emp*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Visual Scripting generated files
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Unity generated asset cache
/[Aa]ssets/[Ss]ceneDependencyCache*

# Windows generated files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS generated files
.DS_Store
.AppleDouble
.LSOverride